{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "passport.schema.json",
  "title": "Material Passport Lite",
  "type": "object",
  "required": ["research_question", "phase", "experiment_intake_declaration"],
  "properties": {
    "research_question": { "type": ["string", "null"] },
    "phase": { "type": "string" },
    "write_status": {
      "type": "string",
      "enum": ["draft", "in_review", "revised", "finalized"]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "statement": { "type": "string" },
          "experiment_id": { "type": "string" },
          "source_id": { "type": ["string", "null"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "planned_experiment_ids": { "type": "array", "items": { "type": "string" } },
    "experiment_intake_declaration": {
      "type": "string",
      "enum": ["experiments_declared", "no_experiments_declared"]
    }
  }
}
